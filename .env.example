# Database Configuration
POSTGRES_DB=jobconnect
POSTGRES_USER=jobconnect
POSTGRES_PASSWORD=jobconnect123

# JWT Configuration
JWT_SECRET=YourSuperSecretKeyThatIsAtLeast32CharactersLong!

# API Configuration (Backend)
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5000
API_URL=http://localhost:5001/api

# Admin Configuration (maps to AdminSettings:Email / AdminSettings:Password in .NET)
AdminSettings__Email=admin@jobconnect.com
AdminSettings__Password=Admin123!

# Database Seeding (set to true to seed demo data on startup)
SEED_DATABASE=false
FORCE_SEED=false

# 100ms Video Conferencing Configuration
HMS_ACCESS_KEY=your_100ms_access_key
HMS_SECRET=your_100ms_secret
HMS_TEMPLATE_ID=your_100ms_template_id

# CORS Configuration (comma-separated list of allowed origins, NO trailing slashes)
CORS_ORIGINS=http://localhost:4200,http://localhost:4201
